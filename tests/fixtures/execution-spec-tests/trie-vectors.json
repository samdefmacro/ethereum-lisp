{
  "format": "ethereum-lisp/trie-vectors-v1",
  "source": "in-repo vectors shaped for ethereum/execution-spec-tests v5.4.0 trie fixture ingestion",
  "executionSpecTests": {
    "release": "v5.4.0",
    "tagTarget": "88e9fb8",
    "archive": "fixtures_stable.tar.gz",
    "status": "seed trie vectors shaped for pinned fixture ingestion; extend with transcribed pinned trie cases"
  },
  "cases": [
    {
      "name": "single-leaf",
      "tags": ["leaf-root", "path-compression"],
      "operations": [
        { "op": "put", "keyAscii": "dog", "valueAscii": "puppy" }
      ],
      "expectedRoot": "0xed6e08740e4a267eca9d4740f71f573e9aabbcc739b16a2fa6c1baed5ec21278",
      "expectedShape": "leaf",
      "expectedRootPathNibbles": [6, 4, 6, 15, 6, 7, 16]
    },
    {
      "name": "delete-missing-key-keeps-leaf",
      "tags": ["leaf-root", "path-compression", "missing-delete-noop"],
      "operations": [
        { "op": "put", "keyAscii": "dog", "valueAscii": "puppy" },
        { "op": "delete", "keyAscii": "cat" }
      ],
      "expectedRoot": "0xed6e08740e4a267eca9d4740f71f573e9aabbcc739b16a2fa6c1baed5ec21278",
      "expectedShape": "leaf",
      "expectedRootPathNibbles": [6, 4, 6, 15, 6, 7, 16],
      "expectedRootValueAscii": "puppy"
    },
    {
      "name": "duplicate-key-overwrites-leaf-value",
      "tags": ["leaf-root", "path-compression", "duplicate-overwrite"],
      "operations": [
        { "op": "put", "keyAscii": "dog", "valueAscii": "puppy" },
        { "op": "put", "keyAscii": "dog", "valueAscii": "hound" }
      ],
      "expectedRoot": "0x1b8a768e0c5ca7d00a88b634464e25599c849977aefed10eb514fc03a9c4c2eb",
      "expectedShape": "leaf",
      "expectedRootPathNibbles": [6, 4, 6, 15, 6, 7, 16],
      "expectedRootValueAscii": "hound"
    },
    {
      "name": "branch-extension-shared-prefix",
      "tags": ["extension-root", "hashed-child-reference", "lookup-assertions"],
      "operations": [
        { "op": "put", "keyAscii": "do", "valueAscii": "verb" },
        { "op": "put", "keyAscii": "dog", "valueAscii": "puppy" },
        { "op": "put", "keyAscii": "doge", "valueAscii": "coin" },
        { "op": "put", "keyAscii": "horse", "valueAscii": "stallion" }
      ],
      "expectedRoot": "0x5991bb8c6514148a29db676a14ac506cd2cd5775ace63c30a4fe457715e9ac84",
      "expectedShape": "extension",
      "expectedRootPathNibbles": [6],
      "expectedChildReference": "hashed",
      "expectedGets": [
        { "keyAscii": "do", "valueAscii": "verb" },
        { "keyAscii": "dog", "valueAscii": "puppy" },
        { "keyAscii": "doge", "valueAscii": "coin" },
        { "keyAscii": "horse", "valueAscii": "stallion" }
      ]
    },
    {
      "name": "extension-embedded-child-reference",
      "tags": ["extension-root", "embedded-child-reference"],
      "operations": [
        { "op": "put", "keyAscii": "do", "valueAscii": "v" },
        { "op": "put", "keyAscii": "dog", "valueAscii": "p" }
      ],
      "expectedRoot": "0x1da465b71da985f1e07e3ed8dcd9e678546164ef2b17fb5c46c678fd91429de3",
      "expectedShape": "extension",
      "expectedRootPathNibbles": [6, 4, 6, 15],
      "expectedChildReference": "embedded"
    },
    {
      "name": "extension-hashed-child-reference",
      "tags": ["extension-root", "hashed-child-reference"],
      "operations": [
        { "op": "put", "keyAscii": "do", "valueAscii": "verb" },
        { "op": "put", "keyAscii": "dog", "valueAscii": "puppy" },
        { "op": "put", "keyAscii": "doge", "valueAscii": "coin" }
      ],
      "expectedRoot": "0xef7b2fe20f5d2c30c46ad4d83c39811bcbf1721aef2e805c0e107947320888b6",
      "expectedShape": "extension",
      "expectedRootPathNibbles": [6, 4, 6, 15],
      "expectedChildReference": "hashed"
    },
    {
      "name": "delete-collapses-path",
      "tags": ["extension-root", "delete-collapse", "lookup-assertions"],
      "operations": [
        { "op": "put", "keyAscii": "do", "valueAscii": "verb" },
        { "op": "put", "keyAscii": "dog", "valueAscii": "puppy" },
        { "op": "put", "keyAscii": "doge", "valueAscii": "coin" },
        { "op": "delete", "keyAscii": "doge" }
      ],
      "expectedRoot": "0x779db3986dd4f38416bfde49750ef7b13c6ecb3e2221620bcad9267e94604d36",
      "expectedShape": "extension",
      "expectedRootPathNibbles": [6, 4, 6, 15],
      "expectedGets": [
        { "keyAscii": "do", "valueAscii": "verb" },
        { "keyAscii": "dog", "valueAscii": "puppy" }
      ],
      "expectedMissing": [
        { "keyAscii": "doge" }
      ]
    },
    {
      "name": "delete-last-entry-empty-root",
      "tags": ["delete-to-empty"],
      "operations": [
        { "op": "put", "keyAscii": "dog", "valueAscii": "puppy" },
        { "op": "delete", "keyAscii": "dog" }
      ],
      "expectedRoot": "0x56e81f171bcc55a6ff8345e692c0f86e5b48e01b996cadc001622fb5e363b421",
      "expectedShape": "empty"
    },
    {
      "name": "root-branch-sparse-children",
      "tags": ["branch-root", "branch-children", "hex-key"],
      "operations": [
        { "op": "put", "keyHex": "0x00", "valueAscii": "left" },
        { "op": "put", "keyHex": "0xf0", "valueAscii": "right" }
      ],
      "expectedRoot": "0x83829cd5772fb13b44be68a75883e4b11b08fe037af8999e7848cfcbd022b8b5",
      "expectedShape": "branch",
      "expectedRootChildren": [0, 15],
      "expectedRootChildReferences": {
        "0": "embedded",
        "15": "embedded"
      }
    },
    {
      "name": "root-branch-mixed-child-references",
      "tags": [
        "branch-root",
        "branch-child-references",
        "embedded-child-reference",
        "hashed-child-reference",
        "hex-key",
        "lookup-assertions"
      ],
      "operations": [
        {
          "op": "put",
          "keyHex": "0x00",
          "valueAscii": "this value is deliberately long enough to hash the child leaf"
        },
        { "op": "put", "keyHex": "0xf0", "valueAscii": "right" }
      ],
      "expectedRoot": "0x4f558f208941283dc0b60b900277073b03079edc0936d703718f88bf511f715d",
      "expectedShape": "branch",
      "expectedRootChildren": [0, 15],
      "expectedRootChildReferences": {
        "0": "hashed",
        "15": "embedded"
      },
      "expectedGets": [
        {
          "keyHex": "0x00",
          "valueAscii": "this value is deliberately long enough to hash the child leaf"
        },
        { "keyHex": "0xf0", "valueAscii": "right" }
      ]
    },
    {
      "name": "delete-missing-branch-child-keeps-root-branch",
      "tags": ["branch-root", "branch-children", "missing-delete-noop", "hex-key"],
      "operations": [
        { "op": "put", "keyHex": "0x00", "valueAscii": "left" },
        { "op": "put", "keyHex": "0xf0", "valueAscii": "right" },
        { "op": "delete", "keyHex": "0x80" }
      ],
      "expectedRoot": "0x83829cd5772fb13b44be68a75883e4b11b08fe037af8999e7848cfcbd022b8b5",
      "expectedShape": "branch",
      "expectedRootChildren": [0, 15]
    },
    {
      "name": "root-branch-value-for-prefix-key",
      "tags": ["branch-root", "branch-children", "branch-value", "hex-key"],
      "operations": [
        { "op": "put", "keyHex": "0x", "valueAscii": "root" },
        { "op": "put", "keyHex": "0x10", "valueAscii": "child" }
      ],
      "expectedRoot": "0x322d957ebcabf5ba295218b9b8920a905f7da6078010c2228989ebcf004e43d8",
      "expectedShape": "branch",
      "expectedRootChildren": [1],
      "expectedRootValueAscii": "root"
    },
    {
      "name": "delete-root-branch-value-collapses-to-leaf",
      "tags": ["leaf-root", "path-compression", "delete-collapse", "branch-value", "hex-key"],
      "operations": [
        { "op": "put", "keyHex": "0x", "valueAscii": "root" },
        { "op": "put", "keyHex": "0x10", "valueAscii": "child" },
        { "op": "delete", "keyHex": "0x" }
      ],
      "expectedRoot": "0xae9b7371f5ef144daa2780a50feb85d5918708e10357eb25c275cc2562f219d4",
      "expectedShape": "leaf",
      "expectedRootPathNibbles": [1, 0, 16]
    },
    {
      "name": "delete-root-branch-child-collapses-to-root-value-leaf",
      "tags": ["leaf-root", "path-compression", "delete-collapse", "branch-value", "hex-key"],
      "operations": [
        { "op": "put", "keyHex": "0x", "valueAscii": "root" },
        { "op": "put", "keyHex": "0x10", "valueAscii": "child" },
        { "op": "delete", "keyHex": "0x10" }
      ],
      "expectedRoot": "0xdecd353bef3878c819cdb73943e0a744d14551d9626f656c4baca465e5db165c",
      "expectedShape": "leaf",
      "expectedRootPathNibbles": [16],
      "expectedRootValueAscii": "root"
    }
  ]
}
